{
  "name": "jc-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "node scripts/check-syntax.mjs",
    "typecheck": "tsc --noEmit",
    "check": "npm run env:check && npm run lint && npm run typecheck && npm run build",
    "draft:article": "node scripts/generate-article.mjs",
    "draft:from-text": "node scripts/generate-article-from-text.mjs --status=draft",
    "draft:publish": "node scripts/generate-article-from-text.mjs --status=published",
    "article:one-shot": "node scripts/generate-article-from-text.mjs --input=drafts/article.txt --status=published",
    "auth:create-import-user": "node scripts/create-import-user.mjs",
    "import:firestore": "node scripts/import-posts-to-firestore.mjs --doc-id=slug",
    "sync:database": "node scripts/sync-database-from-firestore.mjs",
    "sync:all": "npm run sync:database",
    "generate:logo": "node scripts/generate-logo-assets.mjs",
    "content:dedupe": "node scripts/dedupe-database-posts.mjs --write",
    "books:access:dry-run": "node scripts/backfill-book-access-fields.mjs --dry-run",
    "books:access:backfill": "node scripts/backfill-book-access-fields.mjs",
    "categories:dry-run": "node scripts/import-categories-to-firestore.mjs --dry-run",
    "categories:import": "node scripts/import-categories-to-firestore.mjs",
    "categories:counts:dry-run": "node scripts/sync-category-counts.mjs --dry-run",
    "categories:counts:sync": "node scripts/sync-category-counts.mjs",
    "books:schedule:dry-run": "node scripts/schedule-books-publish-at.mjs",
    "books:schedule": "node scripts/schedule-books-publish-at.mjs --apply",
    "env:check": "node scripts/check-env-config.mjs",
    "secret:cron": "node scripts/generate-cron-secret.mjs",
    "clean:artifacts": "node scripts/clean-artifacts.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "sharp": "^0.33.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "firebase": "^12.13.0",
    "firebase-admin": "13.10.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
