rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /blogMetrics/{slug} {
      allow read: if true;
      allow create, update: if request.resource.data.slug == slug
        && request.resource.data.keys().hasOnly([
          'slug',
          'likesCount',
          'savesCount',
          'readLaterCount',
          'viewsCount',
          'totalReadSeconds',
          'readSessionsCount',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /blogs/{postId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.authorId is string
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.slug is string
        && request.resource.data.slug.size() > 0
        && request.resource.data.slug == postId
        && (
          !request.resource.data.keys().hasAny(['author_id'])
          || request.resource.data.author_id == request.auth.uid
        );

      allow update: if request.auth != null
        && resource.data.authorId is string
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
        && resource.data.slug is string
        && resource.data.slug == postId
        && request.resource.data.slug is string
        && request.resource.data.slug == resource.data.slug
        && (
          !request.resource.data.keys().hasAny(['author_id'])
          || request.resource.data.author_id == resource.data.authorId
        );

      allow delete: if request.auth != null
        && resource.data.authorId is string
        && resource.data.authorId == request.auth.uid;
    }

    match /books/{bookId} {
      allow read: if resource.data.publishAt is timestamp
        && resource.data.publishAt <= request.time;
      allow write: if false;
    }

    match /contactLeads/{leadId} {
      allow read, write: if false;
    }

    match /contactLeadsByEmail/{emailId} {
      allow read, write: if false;
    }

    match /newsletterSubscribers/{subscriberId} {
      allow read, write: if false;
    }

    match /newsletter_subscribers/{subscriberId} {
      allow read, write: if false;
    }
  }
}
