rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidNewsletterEmail(value) {
      return value is string
        && value.size() > 4
        && value.size() <= 320
        && value.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]{2,}$');
    }

    function hasOnlyNewsletterFields() {
      return request.resource.data.keys().hasOnly([
        'email',
        'status',
        'subscribedAt',
        'createdAt',
        'updatedAt',
        'consent',
        'consentAt',
        'lastSource',
        'sources',
        'lastSignupAttemptAt',
        'reactivatedAt',
        'unsubscribedAt'
      ]);
    }

    function hasRequiredNewsletterCreateFields() {
      return request.resource.data.keys().hasAll([
        'email',
        'status',
        'subscribedAt',
        'createdAt',
        'updatedAt',
        'consent',
        'consentAt',
        'lastSource',
        'sources',
        'lastSignupAttemptAt'
      ]);
    }

    function hasRequiredNewsletterUpdateFields() {
      return request.resource.data.keys().hasAll([
        'email',
        'status',
        'updatedAt',
        'consent',
        'consentAt',
        'lastSource',
        'sources',
        'lastSignupAttemptAt'
      ]);
    }

    function isValidNewsletterCommon() {
      return hasOnlyNewsletterFields()
        && isValidNewsletterEmail(request.resource.data.email)
        && request.resource.data.status == 'active'
        && request.resource.data.consent == true
        && request.resource.data.lastSource is string
        && request.resource.data.lastSource.size() > 0
        && request.resource.data.lastSource.size() <= 64
        && request.resource.data.sources is list
        && request.resource.data.sources.size() > 0
        && request.resource.data.sources.size() <= 20
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.consentAt is timestamp
        && request.resource.data.lastSignupAttemptAt is timestamp;
    }

    function isTimestampOrMissing(field) {
      return !request.resource.data.keys().hasAny([field]) || request.resource.data[field] is timestamp;
    }

    function isTimestampNullOrMissing(field) {
      return !request.resource.data.keys().hasAny([field])
        || request.resource.data[field] == null
        || request.resource.data[field] is timestamp;
    }

    match /blogMetrics/{slug} {
      allow read: if true;
      allow create, update: if request.resource.data.slug == slug
        && request.resource.data.keys().hasOnly([
          'slug',
          'likesCount',
          'savesCount',
          'readLaterCount',
          'viewsCount',
          'totalReadSeconds',
          'readSessionsCount',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /blogs/{postId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.authorId is string
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.slug is string
        && request.resource.data.slug.size() > 0
        && request.resource.data.slug == postId
        && (
          !request.resource.data.keys().hasAny(['author_id'])
          || request.resource.data.author_id == request.auth.uid
        );

      allow update: if request.auth != null
        && resource.data.authorId is string
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId
        && resource.data.slug is string
        && resource.data.slug == postId
        && request.resource.data.slug is string
        && request.resource.data.slug == resource.data.slug
        && (
          !request.resource.data.keys().hasAny(['author_id'])
          || request.resource.data.author_id == resource.data.authorId
        );

      allow delete: if request.auth != null
        && resource.data.authorId is string
        && resource.data.authorId == request.auth.uid;
    }

    match /newsletter_subscribers/{subscriberId} {
      allow read: if false;

      allow create: if isValidNewsletterCommon()
        && hasRequiredNewsletterCreateFields()
        && request.resource.data.subscribedAt is timestamp
        && request.resource.data.createdAt is timestamp
        && isTimestampOrMissing('reactivatedAt')
        && isTimestampNullOrMissing('unsubscribedAt');

      allow update: if isValidNewsletterCommon()
        && hasRequiredNewsletterUpdateFields()
        && request.resource.data.email == resource.data.email
        && isTimestampOrMissing('subscribedAt')
        && isTimestampOrMissing('createdAt')
        && isTimestampOrMissing('reactivatedAt')
        && isTimestampNullOrMissing('unsubscribedAt');

      allow delete: if false;
    }
  }
}
