# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here
# Optional: folder used by CLI article publisher
VITE_CLOUDINARY_FOLDER=jc-hub/articles

# Optional: project name used as prefix in generated image names
PROJECT_NAME=jc-hub

# Blog source filtering
# Use `*` to show all posts from src/data/database.json, or `article-` to keep only prefixed entries
VITE_SITE_URL=https://jchub.vercel.app
VITE_BLOG_POST_KEY_PREFIXES=*

# Firestore import script (optional, for authenticated import)
# Create/import user helper:
# npm run auth:create-import-user -- --email=import@yourdomain.com --password=StrongPass123!
FIREBASE_IMPORT_EMAIL=your_email@example.com
FIREBASE_IMPORT_PASSWORD=your_password_here
FIREBASE_IMPORT_FORCE_AUTHOR_ID=true

# Newsletter provider
NEWSLETTER_PROVIDER=brevo

# Brevo (server-side only; never prefix these with VITE_)
BREVO_API_BASE_URL=https://api.brevo.com/v3
BREVO_API_KEY=your_brevo_api_key_here

BREVO_LIST_ID_CONTACTS=
BREVO_LIST_ID_NEWSLETTER=

# Optional: if you want to push the contact message into a custom Brevo attribute
# Example: MESSAGE or CONTACT_MESSAGE (must already exist in Brevo contact attributes)
BREVO_CONTACT_MESSAGE_ATTRIBUTE=

# Optional Firestore collection names used by API routes
NEWSLETTER_COLLECTION=newsletterSubscribers
CONTACT_COLLECTION=contactLeads

# Firebase Admin credentials (server-side only)
# Option A: inline JSON. Keep it empty here; paste the real value only in .env or Vercel.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: base64-encoded JSON
FIREBASE_SERVICE_ACCOUNT_BASE64=
# Option C: path (relative to project root)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# Optional protection token for /api/sync-content
SYNC_API_TOKEN=your_sync_api_token_here
